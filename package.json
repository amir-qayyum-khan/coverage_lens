{
    "name": "voyagerr-lens",
    "version": "1.0.0",
    "description": "Desktop application for analyzing code metrics and test coverage",
    "main": "main.js",
    "scripts": {
        "start": "npm run build && electron .",
        "dev": "npm run build && electron . --dev",
        "build": "webpack --mode production",
        "watch": "webpack --mode development --watch",
        "test": "node -e \"console.log('Unit tests are disabled (npm run test:jest to run them).'); process.exit(0)\"",
        "test:watch": "node -e \"console.log('Unit tests are disabled (npm run test:jest -- --watch).'); process.exit(0)\"",
        "test:coverage": "node -e \"console.log('Unit tests are disabled (npm run test:jest -- --coverage).'); process.exit(0)\"",
        "test:jest": "jest",
        "dist": "npm run build && electron-builder"
    },
    "build": {
        "appId": "com.samwe.voyagerrlens",
        "productName": "Voyagerr Lens",
        "directories": {
            "output": "dist_electron"
        },
        "files": [
            "dist/**/*",
            "src/services/**/*",
            "main.js",
            "preload.js",
            "package.json"
        ],
        "win": {
            "target": "portable"
        }
    },
    "keywords": [
        "code-analysis",
        "coverage",
        "jest",
        "electron"
    ],
    "author": "",
    "license": "ISC",
    "devDependencies": {
        "@babel/core": "^7.23.2",
        "@babel/preset-env": "^7.23.2",
        "@babel/preset-react": "^7.24.1",
        "@testing-library/jest-dom": "^5.16.5",
        "@testing-library/react": "^12.1.5",
        "@testing-library/user-event": "^14.4.3",
        "babel-loader": "^9.1.3",
        "css-loader": "^6.8.1",
        "electron": "^25.0.0",
        "electron-builder": "^26.0.12",
        "html-webpack-plugin": "^5.5.3",
        "identity-obj-proxy": "^3.0.0",
        "jest": "^27.5.1",
        "jest-environment-jsdom": "^27.5.1",
        "mini-css-extract-plugin": "^2.9.4",
        "style-loader": "^3.3.3",
        "webpack": "^5.88.2",
        "webpack-cli": "^5.1.4",
        "webpack-dev-server": "^4.15.1"
    },
    "dependencies": {
        "acorn": "^8.11.2",
        "acorn-walk": "^8.3.0",
        "react": "^16.13.1",
        "react-dom": "^16.13.1",
        "xlsx": "^0.18.5"
    }
}